# Copy to .env.local and fill in
DATABASE_URL=postgres://carl:localdev@localhost:5432/vertere_dev
JWT_SECRET=
LOG_LEVEL=debug

# Local dev port. Avoid 8000 (Supabase Kong already binds it on this box).
# Container Apps sets its own $PORT in prod regardless.
PORT=8787

# Mobile API URL (when testing on real devices via cloudflared)
# Local simulator:  http://localhost:8787
# Internal dev:     https://verteredev.noregrets.dev
# Client-facing:    https://vertere.certopartners.com
EXPO_PUBLIC_API_URL=http://localhost:8787

# Origin allow-list for CORS (browser clients only; native Expo Go ignores CORS).
# Add the cloudflared hostname(s) once the tunnel is up.
ALLOWED_ORIGINS=http://localhost:19006
